
# Copyright Header Convention

<rule>
name: copyright_header
description: Defines the required copyright header for all new source files
filters:
  - type: glob
    pattern: "**/*.{js,jsx,json}"

actions:
  - type: inform
    message: |
      Every new source file must begin with the following copyright header:

      ```javascript
      // Copyright ©️ 2024-2025 Sebastian Delmont <sd@ham2k.com>
      // SPDX-License-Identifier: MPL-2.0
      ```

      The header should be followed by a blank line before any imports or code begin.

metadata:
  priority: high
  version: 1.0
</rule>
